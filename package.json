{
    "name": "root",
    "private": true,
    "workspaces": [
        "packages/*"
    ],
    "engines": {
        "node": "20.x"
    },
    "overrides": {
        "eslint": "^8.57.1",
        "react-dom": "^18.2.0",
        "nth-check": "2.0.1",
        "typescript": "^5.0.0",
        "node-forge": "1.3.2",
        "@semantic-release/npm": "^13.1.4",
        "flatted": "3.4.2",
        "@tootallnate/once": "^3.0.1",
        "handlebars": "4.7.9",
        "lodash": "4.18.1",
        "lodash-es": "4.18.1",
        "picomatch": "4.0.4",
        "brace-expansion": "1.1.13",
        "@xmldom/xmldom": "0.8.12",
        "yaml": "2.7.1",
        "serialize-javascript": "7.0.5",
        "express": {
            "path-to-regexp": "0.1.13"
        },
        "react-router": {
            "path-to-regexp": "1.9.0"
        },
        "semantic-release": {
            "conventional-changelog-writer": {
                "handlebars": "4.7.9"
            }
        },
        "@semantic-release/release-notes-generator": {
            "conventional-changelog-writer": {
                "handlebars": "4.7.9"
            }
        },
        "sass": {
            "@parcel/watcher": {
                "picomatch": "4.0.4"
            }
        },
        "lint-staged": {
            "yaml": "2.7.1",
            "cosmiconfig": {
                "yaml": "2.7.1"
            }
        },
        "postcss-loader": {
            "cosmiconfig": {
                "yaml": "2.7.1"
            }
        },
        "workbox-build": {
            "rollup-plugin-terser": {
                "serialize-javascript": "7.0.5"
            }
        },
        "formik": {
            "lodash-es": "4.18.1"
        }
    },
    "devDependencies": {
        "@babel/core": "^7.25.2",
        "@babel/eslint-parser": "^7.25.1",
        "@babel/plugin-proposal-class-properties": "^7.18.6",
        "@babel/plugin-proposal-decorators": "^7.24.7",
        "@babel/plugin-proposal-export-default-from": "^7.24.7",
        "@babel/plugin-proposal-nullish-coalescing-operator": "^7.18.6",
        "@babel/plugin-proposal-object-rest-spread": "^7.20.7",
        "@babel/plugin-proposal-optional-chaining": "^7.21.0",
        "@babel/plugin-syntax-dynamic-import": "^7.8.3",
        "@babel/plugin-transform-class-properties": "^7.25.4",
        "@babel/plugin-transform-export-namespace-from": "^7.24.7",
        "@babel/plugin-transform-nullish-coalescing-operator": "^7.24.7",
        "@babel/plugin-transform-object-rest-spread": "^7.24.7",
        "@babel/plugin-transform-optional-chaining": "^7.24.8",
        "@babel/plugin-transform-private-property-in-object": "^7.24.7",
        "@babel/plugin-transform-unicode-property-regex": "^7.24.7",
        "@babel/preset-env": "^7.25.4",
        "@babel/preset-react": "^7.24.7",
        "@deriv-com/eslint-config-deriv": "2.2.0",
        "@jest/globals": "^29.7.0",
        "@testing-library/jest-dom": "^6.5.0",
        "@testing-library/react": "^14.3.1",
        "@testing-library/react-hooks": "^7.0.2",
        "@testing-library/user-event": "^14.5.2",
        "@types/jest": "^29.5.14",
        "@types/node": "^20.0.0",
        "@types/react": "^18.0.7",
        "@types/react-dom": "^18.0.0",
        "@types/react-router-dom": "^5.1.6",
        "@types/react-virtualized": "^9.21.21",
        "copy-anything": "^4.0.5",
        "dotenv-webpack": "^8.0.1",
        "husky": "^7.0.0",
        "jest": "^29.7.0",
        "jest-chain": "^1.1.6",
        "jest-environment-jsdom": "^29.7.0",
        "jest-extended": "^4.0.2",
        "lint-staged": "^11.2.6",
        "node-abort-controller": "^3.1.1",
        "postcss": "^8.4.24",
        "prettier": "^3.0.0",
        "stylelint": "^16.23.1",
        "stylelint-formatter-pretty": "^2.1.1",
        "stylelint-no-unsupported-browser-features": "^4.0.0",
        "stylelint-selector-bem-pattern": "^4.0.1",
        "stylelint-webpack-plugin": "^5.0.1",
        "ts-jest": "^29.2.5"
    },
    "scripts": {
        "serve": "f () { npm exec --workspace=@deriv/${1:-'*'} -- npm run serve $npm_config_open;}; f",
        "bootstrap": "npm ci --strict-peer-deps --verbose",
        "bootstrap:ci": "npm ci --strict-peer-deps --verbose",
        "bootstrap:dev": "npm install --strict-peer-deps --verbose",
        "clean": "echo \"This will remove ALL node_modules directories in the project.\" && read -p \"Are you sure? (y/N): \" -n 1 -r && echo && if [[ $REPLY =~ ^[Yy]$ ]]; then echo \"Removing all node_modules directories...\" && find . -name \"node_modules\" -type d -prune -exec rm -rf {} + && echo \"All node_modules directories removed\"; else echo \"Operation cancelled\"; fi",
        "build:all": "npm run build --workspace=@deriv/components && npm run build --workspace=@deriv/reports && npm run build --workspace=@deriv/trader && npm run --workspaces --if-present build",
        "generate:colors": "node ./scripts/generate-colors.js",
        "verify:whitelabel": "node ./scripts/verify-white-label.js",
        "test": "npm run test:stylelint && npm run test:eslint-all && npm run test:jest",
        "test:eslint-all": "npm run --workspaces --if-present test:eslint",
        "test:stylelint": "stylelint \"./packages/*/src/**/*.s(a|c)ss\"",
        "test:jest": "jest --all --maxWorkers=${JEST_MAX_WORKERS:-'50%'}",
        "test:ci": "npm run test:stylelint && npm run test:eslint-all && npm run test:jest",
        "stylelint:fix": "stylelint \"./packages/*/src/**/*.s(a|c)ss\" --fix",
        "prettify": "prettier --config ./.prettierrc --write \"./packages/*/{stories,script,src,build}/**/*.{js,jsx,ts,tsx,scss}\"",
        "prepare": "husky install"
    },
    "dependencies": {
        "@babel/plugin-proposal-export-namespace-from": "^7.18.9",
        "@babel/preset-typescript": "^7.24.7",
        "@deriv-com/smartcharts-champion": "^1.9.3",
        "@deriv-com/translations": "^1.4.0",
        "@types/react-transition-group": "^4.4.5",
        "babel-jest": "^29.7.0",
        "dotenv": "^8.2.0",
        "nth-check": "2.0.1",
        "pbkdf2": "^3.1.3",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-svg-core": "3.0.3",
        "react-toastify": "^9.1.3",
        "typescript": "^5.0.0"
    },
    "optionalDependencies": {
        "fsevents": "^2.3.2"
    }
}
